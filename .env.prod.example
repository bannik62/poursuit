# Copié sur le VPS par GitHub Actions → .env.prod (ne pas committer)

NODE_ENV=production
PORT=3000

JWT_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

PUBLIC_URL=https://game.vitalinfo.site
FRONTEND_URL=https://game.vitalinfo.site

MIN_PLAYERS=2
MAX_PLAYERS=4

# Port local nginx (Apache proxy → 127.0.0.1:GAME_HTTP_PORT)
GAME_HTTP_PORT=3333
