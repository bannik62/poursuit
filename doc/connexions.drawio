          <mxGeometry x="40" y="450" width="1520" height="200" as="geometry" />
        </mxCell>
        <mxCell id="apache" value="&lt;b&gt;VirtualHost *:443&lt;/b&gt;&lt;br&gt;game.vitalinfo.site&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;• SSL Let's Encrypt&lt;br&gt;• X-Forwarded-Proto: https&lt;br&gt;• ProxyPass /socket.io/ &lt;b&gt;AVANT&lt;/b&gt; ProxyPass /&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="zone-vps">
          <mxGeometry x="480" y="45" width="280" height="130" as="geometry" />
        </mxCell>
        <mxCell id="apache-socket" value="/socket.io/&lt;br&gt;HTTP polling +&lt;br&gt;upgrade WebSocket" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="zone-vps">
          <mxGeometry x="200" y="70" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="apache-rest" value="/admin/ /joueur/&lt;br&gt;/plateau/ /api/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="zone-vps">
