        </mxCell>
        <mxCell id="s-http" value="&lt;b&gt;HTTP déclencheurs&lt;/b&gt;&lt;br&gt;POST /api/player/join → broadcast session:state&lt;br&gt;POST …/start → game:start&lt;br&gt;POST …/reset → session:reset" style="text;html=1;strokeColor=#666666;fillColor=#ffffff;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="720" y="320" width="320" height="100" as="geometry" />
