        <mxCell id="s-events" value="&lt;b&gt;Événements serveur → clients&lt;/b&gt;&lt;br&gt;session:state — état complet&lt;br&gt;player:joined — nouveau joueur&lt;br&gt;game:start — partie lancée&lt;br&gt;game:dice / game:answer — actions jeu&lt;br&gt;game:over — fin de partie&lt;br&gt;session:reset — session supprimée" style="text;html=1;strokeColor=#666666;fillColor=#ffffff;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=11;" vertex="1" parent="1">
