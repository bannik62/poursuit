        <!-- Docker -->
        <mxCell id="zone-docker" value="Docker Compose (poursuit) — localhost only" style="swimlane;horizontal=0;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="40" y="690" width="1520" height="220" as="geometry" />
        </mxCell>
        <mxCell id="frontend" value="&lt;b&gt;frontend&lt;/b&gt; (nginx :80)&lt;br&gt;127.0.0.1:3333 → conteneur&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;/admin/ /plateau/ /joueur/ → SPAs Svelte&lt;br&gt;/api/* → proxy backend:3000&lt;br&gt;/socket.io/* → proxy backend:3000&lt;br&gt;Connection: upgrade (map polling/ws)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="zone-docker">
          <mxGeometry x="350" y="45" width="320" height="150" as="geometry" />
        </mxCell>
        <mxCell id="backend" value="&lt;b&gt;backend&lt;/b&gt; (Node.js :3000)&lt;br&gt;réseau Docker interne&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Express REST + Socket.IO&lt;br&gt;Sessions en mémoire&lt;br&gt;CORS: FRONTEND_URL + PUBLIC_URL&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="zone-docker">
          <mxGeometry x="850" y="45" width="280" height="150" as="geometry" />
        </mxCell>
        <mxCell id="env-note" value=".env.prod&lt;br&gt;PUBLIC_URL, FRONTEND_URL,&lt;br&gt;JWT_SECRET, GAME_HTTP_PORT=3333" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;size=14;fontSize=11;align=left;" vertex="1" parent="zone-docker">
          <mxGeometry x="30" y="50" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Flow session box -->
        <mxCell id="flow-box" value="&lt;b&gt;Flux lobby (exemple)&lt;/b&gt;&lt;br&gt;1. Admin POST /api/admin/session → sessionId + QR&lt;br&gt;2. Admin socket session:subscribe → room sessionId&lt;br&gt;3. Tel scan QR → POST /api/player/join → broadcast session:state&lt;br&gt;4. Tel socket player:subscribe → reçoit mises à jour live&lt;br&gt;5. Admin reçoit session:state → compteur X/Y, bouton Lancer" style="text;html=1;strokeColor=#666666;fillColor=#ffffff;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="940" width="760" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ports-box" value="&lt;b&gt;Ports&lt;/b&gt;&lt;br&gt;443 → Apache (public)&lt;br&gt;3333 → nginx Docker (localhost VPS)&lt;br&gt;3000 → backend (interne Docker)" style="text;html=1;strokeColor=#666666;fillColor=#ffffff;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="840" y="940" width="320" height="90" as="geometry" />
