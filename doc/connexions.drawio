        <mxCell id="legend-clients" value="&lt;b&gt;Protocoles côté client&lt;/b&gt;&lt;br&gt;• REST → /api/* (login, join, start…)&lt;br&gt;• Socket.IO → /socket.io/* (lobby live, dé, réponses)" style="text;html=1;strokeColor=#999999;fillColor=#ffffff;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="zone-clients">
