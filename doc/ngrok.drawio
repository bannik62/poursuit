                <mxCell id="script" value="&lt;b&gt;./scripts/ngrok-dev.sh&lt;/b&gt;&lt;br&gt;1. docker compose --profile ngrok up&lt;br&gt;2. lit URL sur localhost:4040&lt;br&gt;3. met à jour .env&lt;br&gt;4. redémarre backend" style="shape=note;whiteSpace=wrap;html=1;size=16;fillColor=#fff2cc;strokeColor=#d6b656;align=left;fontSize=11;" parent="docker-zone" vertex="1">
