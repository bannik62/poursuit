# =============================================================================
# Apache — Trivial Asso / Poursuit
# Domaine : https://game.vitalinfo.site
# Chaîne : Internet → Apache (443) → 127.0.0.1:3333 (Docker/nginx) → backend
#
# Installation (une fois sur le VPS) :
#   sudo cp deploy/apache-game-vitalinfo.conf.example /etc/apache2/sites-available/game-vitalinfo.conf
#   sudo a2enmod proxy proxy_http proxy_wstunnel rewrite ssl headers
#   sudo a2ensite game-vitalinfo.conf
#   sudo apache2ctl configtest && sudo systemctl reload apache2
#
# Certificat Let's Encrypt (si pas déjà fait) :
#   sudo certbot --apache -d game.vitalinfo.site
# =============================================================================

# -----------------------------------------------------------------------------
# HTTP (port 80) — redirige tout vers HTTPS
# -----------------------------------------------------------------------------
<VirtualHost *:80>
    ServerName game.vitalinfo.site

    # Redirection permanente : http:// → https:// (SEO + sécurité cookies)
    Redirect permanent / https://game.vitalinfo.site/
</VirtualHost>

# -----------------------------------------------------------------------------
# HTTPS (port 443) — point d'entrée principal
# -----------------------------------------------------------------------------
<VirtualHost *:443>
    ServerName game.vitalinfo.site

    # --- SSL (Let's Encrypt via certbot) ---
    # Certbot remplit souvent ces lignes automatiquement.
    # Si tu édites à la main, décommente et adapte :
    SSLEngine on
    # SSLCertificateFile /etc/letsencrypt/live/game.vitalinfo.site/fullchain.pem
    # SSLCertificateKeyFile /etc/letsencrypt/live/game.vitalinfo.site/privkey.pem
    # Include /etc/letsencrypt/options-ssl-apache.conf

    # --- Proxy général ---
    # Conserve le Host original (game.vitalinfo.site) pour nginx/backend
    ProxyPreserveHost On

    # Indique au backend qu'on est en HTTPS (cookies secure, URLs publiques)
    RequestHeader set X-Forwarded-Proto "https"

    # IP réelle du client (logs, rate-limit éventuel)
    RequestHeader set X-Forwarded-For "%{REMOTE_ADDR}s"

    # --- Socket.IO (TEMPS RÉEL : admin, téléphones, plateau) ---
    # ORDRE CRITIQUE : /socket.io/ DOIT être AVANT ProxyPass /
    # Sinon Apache envoie socket.io comme une page web normale → admin bloqué.
    #
    # Phase 1 du client : polling HTTP (GET/POST long-polling)
    ProxyPass /socket.io/ http://127.0.0.1:3333/socket.io/
    ProxyPassReverse /socket.io/ http://127.0.0.1:3333/socket.io/

    # --- Tout le reste (admin, joueur, plateau, /api) ---
    # Docker écoute sur localhost:3333 (GAME_HTTP_PORT dans .env.prod)
    ProxyPass / http://127.0.0.1:3333/
    ProxyPassReverse / http://127.0.0.1:3333/

    # --- WebSocket (phase 2 Socket.IO après le polling) ---
    # Quand le navigateur envoie Upgrade: websocket, Apache bascule en ws://
    RewriteEngine On
    RewriteCond %{HTTP:Upgrade} =websocket [NC]
    RewriteRule /socket.io/(.*) ws://127.0.0.1:3333/socket.io/$1 [P,L]

    # --- Logs (debug si socket ou 502) ---
    ErrorLog ${APACHE_LOG_DIR}/game-vitalinfo-error.log
    CustomLog ${APACHE_LOG_DIR}/game-vitalinfo-access.log combined
</VirtualHost>
