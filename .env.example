# ── App ──
NODE_ENV=development
PORT=3000

# ── Auth admin ──
JWT_SECRET=change-me-generate-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ── URLs ──
# PC seul : http://localhost:8083
# Telephone (dev WSL) : utilise ngrok → ./scripts/ngrok-dev.sh
PUBLIC_URL=http://localhost:8083
FRONTEND_URL=http://localhost:8083

# ── ngrok (dev téléphone) ──
# Token : https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# ── Jeu ──
MIN_PLAYERS=2
MAX_PLAYERS=4
